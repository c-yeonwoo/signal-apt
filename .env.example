# 저평가 추천 기능용 외부 API 키 (각자 발급, .env 에 실제값 입력)
# 공공데이터포털(data.go.kr): 국토부 실거래가 + 소상공인 상가정보
PUBLIC_DATA_KEY=your_data_go_kr_service_key
# ODsay(lab.odsay.com): 대중교통 길찾기 (업무지구 소요시간)
ODSAY_KEY=your_odsay_key

# VWorld(vworld.kr): 한글 지도 타일 (선택 — 없으면 CartoDB 영문 타일 폴백). 무료 발급, 도메인 등록 필요
VWORLD_KEY=

# 서울 열린데이터광장 (정비사업 upisRebuild 등) — data.seoul.go.kr
SEOUL_OPENAPI_KEY=your-seoul-openapi-key

# AI 심층 리포트(선택) — 미설정 시 규칙기반 리포트로 폴백
ANTHROPIC_API_KEY=
# Opus 4.8 프리미엄 모델을 쓸 계정(콤마구분 이메일). 그 외 계정은 저가 모델(리포트=Sonnet, 비교해설=Haiku)
AI_OPUS_WHITELIST=

# 카카오 로컬 API (근처 공인중개사) — developers.kakao.com, 카카오맵 제품 활성화 필요
KAKAO_REST_API_KEY=

# 임장 리포트(선택) — 미설정 시 검색 링크로 폴백
YOUTUBE_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 자동 백업(선택) — S3 호환 스토리지(R2/S3/Supabase). 미설정 시 백업 비활성
BACKUP_S3_BUCKET=
BACKUP_S3_KEY_ID=
BACKUP_S3_SECRET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=auto
